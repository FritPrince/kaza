{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // CommonJS output so the NestJS API (tsc, no bundler) can consume it;
    // Next.js and Metro handle it transparently.
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
