# --- Core ---
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# --- Database ---
DATABASE_URL=postgresql://kaza:kaza@localhost:5432/kaza?schema=public

# --- Redis (BullMQ generation queue) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- SMS OTP (Termii or Twilio) ---
SMS_PROVIDER=termii
TERMII_API_KEY=

# --- AI providers (never exposed to clients, §7.2) ---
ANTHROPIC_API_KEY=
IMAGE_PROVIDER=replicate
REPLICATE_API_TOKEN=
# Model version hash chosen by the validation sprint (§12), e.g. owner/model:hash
REPLICATE_MODEL_VERSION=
REPLICATE_COST_PER_RUN_USD=0.05
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_COST_PER_RUN_USD=0.04

# --- Object storage (S3-compatible: AWS S3 or Cloudflare R2) ---
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=kaza-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SIGNED_URL_TTL_SECONDS=3600

# --- Payments (§F2 — two aggregators for redundancy) ---
FEDAPAY_ENV=sandbox
FEDAPAY_SECRET_KEY=
KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET_KEY=
# Web page embedding the KkiaPay widget (deployed separately)
KKIAPAY_CHECKOUT_URL=
REVENUECAT_WEBHOOK_SECRET=
