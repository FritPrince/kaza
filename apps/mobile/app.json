{
  "expo": {
    "name": "Kaza",
    "slug": "kaza",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "kaza",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#182F25",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.waouhmonde.kaza",
      "infoPlist": {
        "NSCameraUsageDescription": "Kaza utilise la caméra pour photographier vos pièces à relooker.",
        "NSPhotoLibraryUsageDescription": "Kaza accède à vos photos pour importer une pièce à relooker."
      }
    },
    "android": {
      "package": "com.waouhmonde.kaza",
      "permissions": ["CAMERA"]
    },
    "plugins": ["expo-router", "expo-camera", "expo-image-picker", "expo-secure-store", "expo-font"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
